{
  "manifest_version": 3,
  "key": "",
  "name": "Paprika Bridge",
  "version": "0.3.0",
  "description": "Connect Chrome to a Paprika Hub. By default it auto-syncs the browser's login cookies into the worker fleet's host registry; switch on Developer mode for manual, table-based cookie editing.",
  "permissions": [
    "cookies",
    "storage",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Paprika Bridge",
    "default_icon": {
      "16": "icon-16.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
